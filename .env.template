PROJECT_NAME="SFOACC DB Project"

# ── Server ────────────────────────────────────────────────────
ENVIRONMENT=production          # local | staging | production

# Single source of truth — set your IP or domain name here.
# BACKEND_HOST and BACKEND_CORS_ORIGINS are derived automatically.
# When you get a domain, just update this one value and restart.
DOMAIN=                         # e.g. 194.146.13.3  or  api.sfoacc.org

FRONTEND_HOST=                  # e.g. https://app.sfoacc.org

# ── Security ──────────────────────────────────────────────────
# Generate a strong secret key: openssl rand -hex 32
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=480  # 8 hours

# ── First superuser (created on make setup) ───────────────────
FIRST_SUPERUSER=
FIRST_SUPERUSER_PASSWORD=
FIRST_SUPERUSER_PHONE=

# ── Email (Gmail SMTP) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_USER=
SMTP_PASSWORD=                   # Gmail app password (not your account password)
EMAILS_FROM_EMAIL=
SMTP_TLS=True
SMTP_SSL=False
SMTP_PORT=587

# ── SMS ───────────────────────────────────────────────────────
ARKESEL_API_KEY=
SMS_SENDER_NAME=SFOACC
CHURCH_NAME="St. Francis of Assisi Catholic Church, Ashaley Botwe, Accra"
CHURCH_CONTACT=

# ── PostgreSQL ────────────────────────────────────────────────
# POSTGRES_SERVER=db means the "db" Docker container (do not change for Docker deployments)
POSTGRES_SERVER=db
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=app

# ── Database connection pool ──────────────────────────────────
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=40
DB_POOL_TIMEOUT=60
DB_POOL_RECYCLE=1800

# ── API performance ───────────────────────────────────────────
# Set WEB_CONCURRENCY to match your server's CPU count (run: nproc)
WEB_CONCURRENCY=4
LOG_LEVEL=warning                # debug | info | warning | error
MAX_UPLOAD_SIZE_MB=10

# ── Docker ────────────────────────────────────────────────────
DOCKER_IMAGE_BACKEND=sfoacc-backend
TAG=latest
